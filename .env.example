# ========== 課金が必要なAPI ==========
# OpenAI（軸生成・検索クエリ・選別・構造化）
OPENAI_API_KEY=
# Web検索（SerpAPI）
SERPAPI_API_KEY=

# ========== 以下は無料・任意 ==========
# Inngest（dev: CLI 無料 / 本番: 無料枠あり）
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# 件数・料金を抑える（デフォルト: 有効＝少なめ）
# LIGHT_MODE=false にすると本番向け（目標100件・補充3回・検索5-7件/カテゴリ）
# LIGHT_MODE=true または未設定＝軸2・カテゴリ2・目標10件・補充なし・検索2-3件
# LIGHT_MODE=false 時にのみ有効:
# MAX_CASES_TARGET=100
# MAX_SUPPLEMENT_ROUNDS=3

# Paths（省略時: ./data, ./output）
DATA_DIR=./data
OUTPUT_DIR=./output

# このアプリのURL（Inngest用）。開発: http://localhost:3000 / 本番: https://your-app.example.com
APP_URL=http://localhost:3000

# ========== サーバーデプロイ時のみ ==========
# 他端末の MCP が結果を取得する API にキーを要求する場合
# RESEARCH_AGENT_API_KEY=your-secret

# RunState を DB に保存する場合（未設定なら DATA_DIR のファイルに保存）
# 設定すると複数インスタンス・再起動後も結果が残る（推奨: Render 本番）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
