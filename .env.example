# ========== 課金が必要なAPI ==========
# OpenAI（軸生成・検索クエリ・選別・構造化）
OPENAI_API_KEY=
# Web検索（Serper.dev 推奨。なければ SerpAPI も利用可能）
SERPER_API_KEY=
# 既存環境との互換用（SERPER_API_KEY が優先されます）
SERPAPI_API_KEY=

# ========== 以下は無料・任意 ==========
# Inngest（dev: CLI 無料 / 本番: 無料枠あり）
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# 件数・料金を抑える（デフォルト: 有効＝少なめ）
# LIGHT_MODE=true または未設定＝軽め（軸2・カテゴリ2・目標10件・補充なし・検索2-3件/カテゴリ）
# LIGHT_MODE=false にすると「重め」設定がデフォルトになり（軸5・カテゴリ5・目標100件・補充3回・検索5-7件/カテゴリ）、
# 下記の個別設定でさらに細かく調整できます。
LIGHT_MODE=true

# 軸・カテゴリ数の上限（目安: 軸 2〜10、カテゴリ 2〜10）
# MAX_AXES=2
# MAX_CATEGORIES_PER_AXIS=2

# 1カテゴリあたりの検索結果件数（Web検索APIで取得する URL 数）
# 目安: 軽め 2〜3 件、本番 5〜7 件
# SEARCH_PER_CATEGORY_MIN=2
# SEARCH_PER_CATEGORY_MAX=3

# 目標とする事例数（最終的にこの件数前後を目指す）
# 目安: 軽め 10 件、本番 50〜100 件
# MAX_CASES_TARGET=10

# 補充ラウンド数（0 なら補充なし。大きくするほど時間とコストが増えます）
# 目安: 軽め 0 回、本番 1〜3 回
# MAX_SUPPLEMENT_ROUNDS=0

# Paths（省略時: ./data, ./output）
DATA_DIR=./data
OUTPUT_DIR=./output

# このアプリのURL（Inngest用）。開発: http://localhost:3000 / 本番: https://your-app.example.com
APP_URL=http://localhost:3000

# スクリーン構造化（ページ→事例構造体）の並列処理数
# 大きくすると速くなりますが、LLM のレート制限に当たりやすくなります。
# 目安: ローカル 1〜3、本番 3〜5 から徐々に様子を見る
SCREEN_CONCURRENCY=1

# ========== サーバーデプロイ時のみ ==========
# 他端末の MCP が結果を取得する API にキーを要求する場合
# RESEARCH_AGENT_API_KEY=your-secret

# RunState を DB に保存する場合（未設定なら DATA_DIR のファイルに保存）
# 設定すると複数インスタンス・再起動後も結果が残る（推奨: Render 本番）
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
